---
# Dynamic configuration for services not running in Docker
# Services running in Docker should use labels in their docker-compose files

http:
  routers:
    traefik-dashboard:
      rule: "Host(`traefik.{{ base_domain }}`)"
      service: api@internal
      entryPoints: ["web"]
      middlewares: ["secure-headers"]
    
    proxmox-dashboard:
      rule: "Host(`proxmox.{{ base_domain }}`)"
      service: proxmox-service
      entryPoints: ["web"]
      
    gitlab-route:
      rule: "Host(`gitlab.{{ base_domain }}`)"
      service: gitlab-service
      entryPoints: ["web"]

    seafile-route:
      rule: "Host(`seafile.{{ base_domain }}`)"
      service: seafile-service
      entryPoints: ["web"]

    kong-admin:
      rule: "Host(`kong.{{ base_domain }}`) && PathPrefix(`/admin-api`)"
      service: kong-admin
      entryPoints: ["web"]
      middlewares: 
        - "kong-strip-prefix"

    kong-gateway:
      rule: "Host(`kong.{{ base_domain }}`)"
      service: kong-gateway
      entryPoints: ["web"]    

  services:
    proxmox-service:
      loadBalancer:
        servers:
          - url: "https://192.168.1.200:8006"
        serversTransport: proxmoxTransport

    gitlab-service:
      loadBalancer:
        servers:
          - url: "http://192.168.1.230:80"

    seafile-service:
      loadBalancer:
        servers:
          - url: "http://192.168.1.320:80"

    kong-admin:
      loadBalancer:
        servers:
          - url: "http://192.168.1.63:8001"

    kong-gateway:
      loadBalancer:
        servers:
          - url: "http://192.168.1.63:8002"

  serversTransports:
    proxmoxTransport:
      insecureSkipVerify: true

  middlewares:
    secure-headers:
      headers:
        sslRedirect: true
        stsSeconds: 31536000
        stsIncludeSubdomains: true
        stsPreload: true
        forceSTSHeader: true
        customFrameOptionsValue: "SAMEORIGIN"
        contentTypeNosniff: true
        browserXssFilter: true
        referrerPolicy: "strict-origin-when-cross-origin"
    
    # WebSocket support middleware (for n8n, etc.)
    websocket-headers:
      headers:
        customRequestHeaders:
          X-Forwarded-Proto: "https"
        customResponseHeaders:
          X-Frame-Options: "SAMEORIGIN"

    kong-strip-prefix:
      stripPrefix:
        prefixes:
          - "/admin-api"
