# Local .terraform directory
.terraform/

# Terraform state files - never commit these
*.tfstate
*.tfstate.backup
.terraform.tfstate.lock.info

# Terraform variable files with secrets - use .example files instead
*.tfvars
!*.tfvars.example

# Backend config with sensitive values - use .example files instead
backend.hcl
!backend.hcl.example

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Crash log files
crash.log
crash.*.log
